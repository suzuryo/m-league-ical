{
  "name": "m-league-ical",
  "version": "1.0.0",
  "description": "Mリーグのスケジュールを取得してiCal形式で出力してGithub Pagesにデプロイする",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "fetch": "tsx src/fetcher.ts",
    "start": "tsx src/fetcher.ts",
    "dev": "tsx src/fetcher.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage"
  },
  "keywords": [
    "m-league",
    "fetcher",
    "schedule"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "yaml": "2.9.0"
  }
}
